# ──────────────────────────────────────────────
# SE-Agents v1.0.0 — environment configuration
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# ── Chat Adapters (enable one or more) ──────────────────────────────────────

# Telegram — get token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AAF...

# Zalo Official Account
ZALO_OA_ACCESS_TOKEN=
ZALO_WEBHOOK_PORT=8080
ZALO_WEBHOOK_SECRET=

# CLI adapter (terminal — useful for local dev/testing)
ENABLE_CLI=false

# ── Database ─────────────────────────────────────────────────────────────────

# MongoDB URI — local or Atlas
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=se_agents

# ── Workspace ─────────────────────────────────────────────────────────────────

# Directory where agent output is written as real project files
# In Docker, this is mounted as /projects inside the container
PROJECTS_DIR=/tmp/projects
