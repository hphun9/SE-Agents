# ──────────────────────────────────────────────
# SE-Agents — environment configuration
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# Telegram bot token — get from @BotFather on Telegram
# https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=123456789:AAF...

# MongoDB connection
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net
MONGODB_URI=mongodb://localhost:27017

# MongoDB database name (created automatically if it doesn't exist)
MONGODB_DB=se_agents

# (Docker only) Host directory to mount as /projects inside the container
# Your fix commands will use paths like /projects/my-app
PROJECTS_DIR=/home/youruser/projects
